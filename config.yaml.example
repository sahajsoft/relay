server:
  port: 8080

providers:
  openai:
    base_url: https://api.openai.com
    api_key: ${OPENAI_API_KEY}
    auth_header: Authorization
    auth_scheme: Bearer

  anthropic:
    base_url: https://api.anthropic.com
    api_key: ${ANTHROPIC_API_KEY}
    auth_header: x-api-key
    auth_scheme: ""
